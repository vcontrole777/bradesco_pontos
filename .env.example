# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard → Settings → API

# Project Reference ID (ex: abcdefghijklmnopqrst)
VITE_SUPABASE_PROJECT_ID=

# Anon/public key (JWT)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Project URL (ex: https://abcdefghijklmnopqrst.supabase.co)
VITE_SUPABASE_URL=

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Senha de acesso ao painel /admin
VITE_ADMIN_PASSWORD=

# ── Cloudflare Turnstile — Site Key (frontend, pública) ──────────────────────
# Obtenha em: https://dash.cloudflare.com → Turnstile
# Deixe em branco para desabilitar o CAPTCHA
VITE_TURNSTILE_SITE_KEY=


# ==============================================================================
# SECRETS DAS EDGE FUNCTIONS
# Em produção: configure via `supabase secrets set CHAVE=valor`
# Em desenvolvimento local: coloque aqui para uso com `supabase functions serve`
# NUNCA exponha estas chaves no frontend (sem prefixo VITE_)
# ==============================================================================

# ── Risenew (envio de SMS / OTP) ──────────────────────────────────────────────
# Obtenha em: https://risenew.lat → painel de credenciais
RISENEW_API_KEY=
RISENEW_API_SECRET=

# ── Cloudflare Turnstile — Secret Key (backend, privada) ─────────────────────
# Par da VITE_TURNSTILE_SITE_KEY — nunca expor no frontend
TURNSTILE_SECRET_KEY=

# ── IPInfo (geolocalização e detecção de VPN/proxy) ──────────────────────────
# Obtenha em: https://ipinfo.io/account/token
IPINFO_TOKEN=

# ── ZenRows (scraping para consulta de segmento bancário) ────────────────────
# Obtenha em: https://app.zenrows.com → API Key
ZENROWS_API_KEY=

# ── Meta Pixel + Conversions API ─────────────────────────────────────────────
# Obtenha em: Meta Business Suite → Gerenciador de Eventos → seu pixel
# VITE_META_PIXEL_ID: exposto no frontend (build-time) — só o ID numérico, não é sensível
VITE_META_PIXEL_ID=
# META_PIXEL_ID + META_CAPI_ACCESS_TOKEN: usados pela edge function meta-capi
# Configure via: supabase secrets set META_PIXEL_ID=... META_CAPI_ACCESS_TOKEN=...
# NUNCA exponha META_CAPI_ACCESS_TOKEN no frontend (sem prefixo VITE_)
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
