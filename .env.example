# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre esses valores em: https://supabase.com/dashboard → Settings → API

# Project Reference ID (ex: abcdefghijklmnopqrst)
VITE_SUPABASE_PROJECT_ID=

# Anon/public key (JWT)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Project URL (ex: https://abcdefghijklmnopqrst.supabase.co)
VITE_SUPABASE_URL=

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Senha de acesso ao painel /admin
VITE_ADMIN_PASSWORD=

# ── Cloudflare Turnstile (opcional) ──────────────────────────────────────────
# Obtenha em: https://dash.cloudflare.com → Turnstile
# Deixe em branco para desabilitar a proteção de CAPTCHA
VITE_TURNSTILE_SITE_KEY=
